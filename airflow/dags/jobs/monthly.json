        {
            "function": "rest_api_to_pg",
            "target_conn_id": "pg-bssn-dwh",
            "api_url": "http://dummy-api-server:8000/stakeholder",
            "dst": "public.stakeholder_dst",
            "load_type": "upsert",
            "keys": ["id_stakeholder"]
        }
    ]
}